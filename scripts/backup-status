#!/usr/bin/env bash

set -euo pipefail

namespace=""
pvcs=()
repo_type="filesystem"
repo_pvc="backup-repo"
image="restic/restic:0.18.0"
timeout="5m"
format="table"
latest="false"

usage() {
  cat <<'EOF'
Usage: scripts/backup-status --namespace <ns> --pvc <pvc> [--pvc <pvc> ...] [options]

Options:
  --repo-type <filesystem|s3>   Repo type (default: filesystem)
  --repo-pvc <name>             Repo PVC name for filesystem repos (default: backup-repo)
  --image <image>               Restic image (default: restic/restic:0.18.0)
  --timeout <duration>          Wait timeout (default: 5m)
  --format <table|restore-as-of> Output format (default: table)
  --latest                       Only show the most recent snapshot
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --namespace)
      namespace="$2"
      shift 2
      ;;
    --pvc)
      pvcs+=("$2")
      shift 2
      ;;
    --repo-type)
      repo_type="$2"
      shift 2
      ;;
    --repo-pvc)
      repo_pvc="$2"
      shift 2
      ;;
    --image)
      image="$2"
      shift 2
      ;;
    --timeout)
      timeout="$2"
      shift 2
      ;;
    --format)
      format="$2"
      shift 2
      ;;
    --latest)
      latest="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if [ -z "${namespace}" ] || [ ${#pvcs[@]} -eq 0 ]; then
  usage
  exit 1
fi

find_secret() {
  local ns="$1"
  local pvc_name="$2"
  local candidates

  # New BackupPolicy naming convention.
  candidates="$(kubectl -n "${ns}" get secret -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' | grep -E "^backup-repo-.*-${pvc_name}$" || true)"

  # Legacy script naming convention.
  if [ -z "${candidates}" ]; then
    candidates="$(kubectl -n "${ns}" get secret -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' | grep -E "^${pvc_name}-backup-repository$" || true)"
  fi

  if [ -z "${candidates}" ]; then
    return 1
  fi

  echo "${candidates}" | head -n 1
}

volume_yaml=""
mount_yaml=""
if [ "${repo_type}" = "filesystem" ]; then
  mount_yaml=$(cat <<'EOF'
          volumeMounts:
            - name: repo
              mountPath: /mnt/restic-repo
EOF
)
  volume_yaml=$(cat <<EOF
      volumes:
        - name: repo
          persistentVolumeClaim:
            claimName: ${repo_pvc}
EOF
)
fi

for pvc in "${pvcs[@]}"; do
  secret="$(find_secret "${namespace}" "${pvc}")"
  if [ -z "${secret}" ]; then
    echo "No backup secret found for PVC ${pvc} in namespace ${namespace}." >&2
    continue
  fi

  job="backup-status-${pvc}-$(date +%Y%m%d%H%M%S)"

  cat <<EOF | kubectl -n "${namespace}" apply -f -
apiVersion: batch/v1
kind: Job
metadata:
  name: ${job}
spec:
  backoffLimit: 0
  template:
    spec:
      restartPolicy: Never
      containers:
        - name: restic
          image: ${image}
          imagePullPolicy: IfNotPresent
          envFrom:
            - secretRef:
                name: ${secret}
${mount_yaml}
          env:
            - name: OUTPUT_FORMAT
              value: "${format}"
            - name: LATEST_ONLY
              value: "${latest}"
            - name: PVC_NAME
              value: "${pvc}"
          command:
            - /bin/sh
            - -c
            - |
              if [ "\${OUTPUT_FORMAT}" = "restore-as-of" ]; then
                echo "PVC: \${PVC_NAME}"
                restic snapshots --json \
                  | grep -oE '"id":"[^"]+"' \
                  | cut -d\" -f4 > /tmp/ids.txt
                restic snapshots --json \
                  | grep -oE '"time":"[^"]+"' \
                  | cut -d\" -f4 > /tmp/times.txt
                if [ "\${LATEST_ONLY}" = "true" ]; then
                  id="\$(tail -n 1 /tmp/ids.txt)"
                  time="\$(tail -n 1 /tmp/times.txt)"
                  printf 'restoreAsOf: "%s"  # %s\n' "\${time}" "\${id}"
                else
                  paste /tmp/ids.txt /tmp/times.txt \
                    | while read -r id time; do
                        printf 'restoreAsOf: "%s"  # %s\n' "\${time}" "\${id}"
                      done
                fi
              else
                if [ "\${LATEST_ONLY}" = "true" ]; then
                  restic snapshots | tail -n 2
                else
                  restic snapshots
                fi
              fi
${volume_yaml}
EOF

  if ! kubectl -n "${namespace}" wait --for=condition=complete "job/${job}" --timeout="${timeout}"; then
    echo "Job did not complete successfully for PVC ${pvc}." >&2
    kubectl -n "${namespace}" logs "job/${job}" || true
    kubectl -n "${namespace}" describe "job/${job}" || true
    exit 1
  fi

  kubectl -n "${namespace}" logs "job/${job}"
  kubectl -n "${namespace}" delete "job/${job}" --ignore-not-found
done
